{
  "annotations": [
    {
      "start_time": 0,
      "end_time": 3,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "كيف تعلمت الإشارة؟"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Interviewer محاور",
          "tag": "غفران"
        }
      ],
      "uuid": "90dc564c-4adf-4fd1-8165-795f0ff2f800"
    },
    {
      "start_time": 2,
      "end_time": 5,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "أنا اتعلمت عشان أمي وأبويا صم"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "08d9d8d9-9930-41be-a638-42164320bd9d"
    },
    {
      "start_time": 5,
      "end_time": 11,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "اشارتي اتطورت من أهلي وثم التحقت بمدرسة الأمل وكملت التعلم من الطلاب التانيين"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "4d0169f2-7143-4a88-b3b8-f1bcdc4fa4d7"
    },
    {
      "start_time": 20,
      "end_time": 21,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "ماذا عنك؟"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Interviewer محاور",
          "tag": "غفران"
        }
      ],
      "uuid": "fd97c25f-d15c-4f17-9a36-9e5c94d69782"
    },
    {
      "start_time": 20,
      "end_time": 26,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "في الاول لما دخلت المدرسة, اشارتي كانت ضعيفة شوية"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "اسلام"
        }
      ],
      "uuid": "cc1dd595-0a14-4069-aeea-a893627104ae"
    },
    {
      "start_time": 27,
      "end_time": 33,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "كنت بتعلم الاشارة لما عرفت عن الجمعية هنا في المنشية فجيت هنا واتعلمت أكتر"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "اسلام"
        }
      ],
      "uuid": "070f3ecd-b6d6-4162-a8ed-c5ccdf6b0ec3"
    },
    {
      "start_time": 38,
      "end_time": 45,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "فهّمه ان الجمعية زي أمنا"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "349da828-b57e-42ee-aebd-9b645069f6fe"
    },
    {
      "start_time": 45,
      "end_time": 51,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "يعني في المدرسة بنتعمل حبة صغيرة بس وبعد المدرسة بنيجي هنا للجمعية"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "0fb2555e-e8a0-4e28-aab5-60765a2a0587"
    },
    {
      "start_time": 52,
      "end_time": 59,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "هو دا المكان اللي احنى بنتعلم فيه. المكان دا زي أم لكل الصم في الاسكندية. هو فاهم؟"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "ef8fa90a-80b5-424f-9eaf-08d83e14ac24"
    },
    {
      "start_time": 63,
      "end_time": 69,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "الجمعية قديمة. هي موجودة من سنة ١٩٥٧"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "9d193e3d-5fdb-43ba-93e9-13e7d99cda2f"
    },
    {
      "start_time": 70,
      "end_time": 73,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "أنا كنت لسه مش مولود"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "ef054e71-be02-4753-9982-987f84310c83"
    },
    {
      "start_time": 73,
      "end_time": 76,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "افتتحت في سنة ١٩٥٧"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "6d5ed2d9-41c6-4632-a578-0d6fbf3cfdf0"
    },
    {
      "start_time": 76,
      "end_time": 83,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "وبعد كدا اتولدنا انا واخواتي الصم وبابا كان بيخلينا نيجي هنا عشان نتعلم"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "d9a4fd9c-50cf-4306-9f75-c86ccc90d765"
    },
    {
      "start_time": 86,
      "end_time": 93,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "فيه مدرسة للصم وفيه مدرسة لضعاف السمع. الاتنين بييجوا هنا."
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "054ceb6b-c2e1-4345-a29e-a48567b9379d"
    },
    {
      "start_time": 100,
      "end_time": 102,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "وماذا عن حضرتك؟"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Interviewer محاور",
          "tag": "غفران"
        }
      ],
      "uuid": "6dce8288-d637-4e39-8464-6104f39060ae"
    },
    {
      "start_time": 101,
      "end_time": 105,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "في المدرسة التعليم مش قد كدا"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "اسلام"
        }
      ],
      "uuid": "38599b77-3296-4149-8989-dac5bb3afe32"
    },
    {
      "start_time": 105,
      "end_time": 108,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "بس الجمعية بتخطط لتعليم الصم"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "اسلام"
        }
      ],
      "uuid": "945848d6-bf4b-4d44-97d2-829551c64380"
    },
    {
      "start_time": 108,
      "end_time": 111,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "وبتخطط للاحتياجات النفسية"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "اسلام"
        }
      ],
      "uuid": "edd1e0cc-7094-478b-9a3b-19d683aa4df5"
    },
    {
      "start_time": 111,
      "end_time": 118,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "تعلمنا وتطورنا بشكل كبير بفضل المكان دا!"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "اسلام"
        }
      ],
      "uuid": "2d11617b-9817-4464-a350-f46190a63331"
    },
    {
      "start_time": 169,
      "end_time": 174,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "انت بتعرف تقرأ وتكتب عربي كويس ولا لا وليه؟"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Interviewer محاور",
          "tag": "غفران"
        }
      ],
      "uuid": "e7514954-96cf-4f6a-b7ce-e376937efc5c"
    },
    {
      "start_time": 173,
      "end_time": 179,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "في المدرسة مفيش تربية خالص"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "3a992d24-fc17-4d2d-9f99-e21422595b59"
    },
    {
      "start_time": 179,
      "end_time": 184,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "أنا كان عندي حماس اتعلم بنفسي"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "45158866-5884-480a-af45-7e9aac624172"
    },
    {
      "start_time": 184,
      "end_time": 188,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "أهلي علموني شوية وضفت حبة بنفسي"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "f87de4d7-243d-43c2-822b-2f19b25aca5c"
    },
    {
      "start_time": 188,
      "end_time": 192,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "بس كدا"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "b8d84505-fa52-422c-8106-f6b94861e24f"
    },
    {
      "start_time": 192,
      "end_time": 194,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "وكمان أنا قوي في الرياضيات"
            }
          ]
        }
      ],
      "tags": [
        {
          "category": "Participant مشارك",
          "tag": "عبدالعزيز"
        }
      ],
      "uuid": "1304d552-5731-4cef-af05-50a60d61681c"
    },
    {
      "start_time": 197,
      "end_time": 205,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "أنا لو بقرأ حاجة ومعرفش كلمة أخويا اللي بيسمع بيفهّمني وبعد كدا ببقى عارف بس في مدرسة الأمل عمره ما كان في تعليم"
            }
          ]
        }
      ],
      "tags": [
